{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,

    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],

    "module": "ESNext",
    "moduleResolution": "bundler",

    "jsx": "react-jsx",

    "strict": true,

    "skipLibCheck": true,

    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,

    "noEmit": true,

    "baseUrl": ".",

    "paths": {
      "@/*": [
        "./src/*"
      ]
    },

    "types": [
      "node"
    ]
  },

  "include": [
    "src",
    "vite.config.ts"
  ],

  "references": [
    {
      "path": "./tsconfig.node.json"
    }
  ]
}
